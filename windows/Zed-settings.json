// Zed settings (Windows sandbox VM)
//
// Kept separate from the macOS zed/ topic on purpose -- this VM only needs
// the editor to look right. The "LSD Warm" theme is installed by
// bootstrap-phase1.ps1 into %APPDATA%\Zed\themes\lsd-warm.json.
{
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "buffer_font_family": "Lilex Nerd Font",
  "terminal": {
    "font_family": "Lilex Nerd Font"
  },
  "theme": {
    "mode": "light",
    "light": "LSD Warm Light",
    "dark": "LSD Warm Dark"
  },
  "icon_theme": {
    "mode": "light",
    "light": "Colored Zed Icons Theme Light",
    "dark": "Colored Zed Icons Theme Light"
  }
}
